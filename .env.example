# Copy to `.env` and fill in your free key from https://www.football-data.org/client/register
# The Vite dev proxy (dev) and server/proxy.mjs (production, `npm run proxy`) both read
# this and inject it as the `X-Auth-Token` header, so the key is never exposed to the
# browser. Without it, the app runs on seeded data.
FOOTBALL_DATA_TOKEN=
